# 笔记与简历
NOTES_DIR=./notes
RESUME_PATH=./resume.md

# API Keys（按需填入；至少要选定 LLM_PROVIDER 对应那一个）
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# 嵌入：可独立指定 key 与 base_url（OpenAI 兼容网关，如阿里云 DashScope / SiliconFlow）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=100

# LLM 提供方
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_BASE_URL=

# ASR：browser（Web Speech，无需后端）或 openai（Whisper）
ASR_PROVIDER=browser
ASR_MODEL=whisper-1

# 检索
RETRIEVAL_TOP_K=8
RERANK_TOP_K=3
RETRIEVAL_THRESHOLD=0.5
VECTOR_WEIGHT=0.7
BM25_WEIGHT=0.3
MAX_CHUNK_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# 超时
ASR_TIMEOUT_S=8
EMBED_TIMEOUT_S=15
LLM_FIRST_TOKEN_TIMEOUT_S=10
LLM_TOTAL_TIMEOUT_S=30
